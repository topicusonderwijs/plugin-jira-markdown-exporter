{
  "manifest_version": 3,
  "name": "Jira Markdown Exporter",
  "version": "1.0.0",
  "description": "Export Jira Cloud issues to clean Markdown. Open source, no telemetry, uses your existing Jira session.",
  "homepage_url": "https://github.com/topicusonderwijs/plugin-jira-markdown-exporter",
  "permissions": ["activeTab", "scripting", "downloads", "clipboardWrite", "storage"],
  "host_permissions": ["https://*.atlassian.net/*"],
  "optional_host_permissions": ["https://*/*"],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Export this Jira issue to Markdown",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.atlassian.net/*"],
      "js": [
        "src/adfToMarkdown.js",
        "src/jiraToMarkdown.js",
        "src/domScraper.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
